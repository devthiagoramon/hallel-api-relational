  COLE_O_CONTEUDO_DO_ARQUIVO_crypto-avatar.json_AQUI
EOT

google_services_json           = <<-EOT
  COLE_O_CONTEUDO_DO_ARQUIVO_google-services.json_AQUI
EOT

hallel_messaging_firebase_json = <<-EOT
